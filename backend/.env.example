SECRET_KEY=change_this_secret_key
MONGO_URI=mongodb://localhost:27017/helmet_safety_db

# SMTP (Gmail App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
